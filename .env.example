# EduTrack Configuration
# Copy this file to .env and fill in your actual values
# NEVER commit the real .env file to git

# ─────────────────────────────────────────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=edutrack_db
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# ─────────────────────────────────────────────────────────────────────────────
# APPLICATION
# ─────────────────────────────────────────────────────────────────────────────
APP_NAME=EduTrack
BASE_URL=http://localhost/edutrack
APP_ENV=development
SCHOOL_NAME=Your School Name
ACADEMIC_YEAR=2025/2026
ACTIVE_SEMESTER=2

# ─────────────────────────────────────────────────────────────────────────────
# SECURITY - CRITICAL: Generate new values for production
# ─────────────────────────────────────────────────────────────────────────────
# Generate APP_SECRET:    php -r "echo bin2hex(random_bytes(32));"
# Generate PASSWORD_PEPPER: php -r "echo bin2hex(random_bytes(16));"
APP_SECRET=58fafe95000ee16d809857832a248309e17e1c92ee8f32a205c5fe8638e0fe65
PASSWORD_PEPPER=b428852c0d71a5faa88de7e77779300e
SESSION_NAME=EDUTRACK_SESSION
SESSION_LIFETIME=28800
CSRF_TOKEN_BYTES=32

# ─────────────────────────────────────────────────────────────────────────────
# ATTENDANCE
# ─────────────────────────────────────────────────────────────────────────────
ATTENDANCE_WINDOW_MINUTES=10
ATTENDANCE_ALERT_THRESHOLD=75
DISPUTE_WINDOW_HOURS=24
LIVE_FEED_INTERVAL_SECONDS=5

# ─────────────────────────────────────────────────────────────────────────────
# FILE UPLOADS
# ─────────────────────────────────────────────────────────────────────────────
MAX_CSV_SIZE_BYTES=5242880
ROWS_PER_PAGE=25

# ─────────────────────────────────────────────────────────────────────────────
# EMAIL / NOTIFICATIONS (optional)
# ─────────────────────────────────────────────────────────────────────────────
SMTP_ENABLED=false
SMTP_HOST=localhost
SMTP_PORT=25
SMTP_AUTH=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=no-reply@school.local
SMTP_FROM_NAME=EduTrack

# ─────────────────────────────────────────────────────────────────────────────
# TIMEZONE
# ─────────────────────────────────────────────────────────────────────────────
# Full list: https://www.php.net/manual/en/timezones.php
TIMEZONE=Africa/Nairobi
