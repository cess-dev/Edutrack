{
    "name": "edutrack/student-monitoring-system",
    "description": "Locally-hosted school student monitoring system built with PHP and MySQL",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": ">=8.1",
        "mpdf/mpdf": "^8.2",
        "phpmailer/phpmailer": "^6.8"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "EduTrack\\": "backend/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "composer/package-versions-deprecated": true
        }
    },
    "scripts": {
        "post-install-cmd": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ]
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}